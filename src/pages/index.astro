---
// 1. 設定エリア（ここを書き換えるだけでサイトが完成します）
const airbnbLink = "https://www.airbnb.jp/rooms/YOUR_ID";
const bookingLink = "https://www.booking.com/hotel/YOUR_ID";
const hostName = "オーナー名";
const stayName = "宿の名前 - 〇〇別荘";

import "../styles/global.css";
---

<html lang="ja" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{stayName}</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;400;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#faf9f6] text-stone-900 font-['Noto_Serif_JP',serif] leading-relaxed pb-24">

    <!-- ナビゲーション -->
    <header class="fixed top-0 left-0 w-full z-[100] bg-white/80 backdrop-blur-md border-b border-stone-100">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <a href="/" class="text-xl tracking-[0.3em] font-light text-stone-800 uppercase">{stayName}</a>
        <nav class="hidden md:flex items-center gap-10 text-xs tracking-[0.2em] text-stone-600 uppercase">
          <a href="#concept" class="hover:text-stone-900 transition text-stone-500">Concept</a>
          <a href="#amenities" class="hover:text-stone-900 transition text-stone-500">Amenities</a>
          <a href="#gallery" class="hover:text-stone-900 transition text-stone-500">Gallery</a>
          <button id="open-reserve-pc" class="bg-stone-900 text-white px-6 py-2 rounded-full hover:bg-stone-700 transition tracking-widest ml-4">Reserve</button>
        </nav>
        
        <!-- スマホ用ハンバーガーボタン -->
        <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 z-[110] relative p-2">
          <span class="w-6 h-[1px] bg-stone-900 transition-all duration-300" id="line1"></span>
          <span class="w-6 h-[1px] bg-stone-900 transition-all duration-300" id="line2"></span>
        </button>
      </div>

      <!-- スマホ用メニュー画面 -->
      <div id="mobile-menu" class="fixed inset-0 bg-white z-[100] flex flex-col items-center justify-center gap-8 text-xl tracking-[0.3em] font-light translate-x-full transition-transform duration-500 md:hidden">
        <a href="#concept" class="mobile-link">Concept</a>
        <a href="#amenities" class="mobile-link">Amenities</a>
        <a href="#gallery" class="mobile-link">Gallery</a>
      </div>
    </header>

    <!-- 1. ヒーローセクション -->
    <section class="relative h-screen w-full overflow-hidden">
      <div class="absolute inset-0 bg-stone-900/20 z-10"></div>
      <!-- 画像URLは後ほど /img/hero.jpg 等に書き換えてください -->
      <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=1600&q=80" class="object-cover w-full h-full" alt="Main Visual" />
      <div class="absolute inset-0 z-20 flex flex-col items-center justify-center text-white p-4 text-center">
        <span class="text-xs tracking-[0.4em] mb-6 opacity-80 uppercase font-sans">Private Villa Rental</span>
        <h1 class="text-4xl md:text-7xl mb-12 tracking-[0.2em] font-extralight leading-tight">{stayName}</h1>
        <div class="w-[1px] h-24 bg-white/60"></div>
      </div>
    </section>

    <!-- 2. コンセプト -->
    <section id="concept" class="max-w-4xl mx-auto py-40 px-8 text-center scroll-mt-20">
      <span class="text-xs tracking-[0.4em] text-stone-400 block mb-8 uppercase font-sans">The Concept</span>
      <h2 class="text-3xl font-light mb-16 tracking-widest text-stone-800 leading-extra-loose">日常を脱ぎ捨て、<br>静寂と対話する。</h2>
      <p class="text-stone-600 leading-[2.5] font-light text-lg">
        {hostName}がプロデュースしたこの空間は、<br>
        ゲストが「何もしない贅沢」を享受するためだけに設計されました。
      </p>
    </section>

    <!-- 3. アメニティ -->
    <section id="amenities" class="py-32 bg-stone-100 px-8 scroll-mt-20">
      <div class="max-w-5xl mx-auto text-center">
        <span class="text-xs tracking-[0.4em] text-stone-400 block mb-4 uppercase font-sans">Comfort</span>
        <h2 class="text-2xl font-light tracking-widest text-stone-800 mb-20">充実の設備・アメニティ</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-y-16 gap-x-8">
          <div class="flex flex-col items-center group">
            <div class="w-14 h-14 mb-6 border border-stone-300 rounded-full flex items-center justify-center group-hover:bg-stone-900 group-hover:text-white transition-all duration-500 text-xl text-stone-400 group-hover:text-white">☕</div>
            <h3 class="text-sm font-bold mb-3 tracking-wider">Cafe Bar</h3>
            <p class="text-[11px] text-stone-500 leading-relaxed font-sans font-light">本格マシンで楽しむ<br>至福の一杯</p>
          </div>
          <div class="flex flex-col items-center group">
            <div class="w-14 h-14 mb-6 border border-stone-300 rounded-full flex items-center justify-center group-hover:bg-stone-900 group-hover:text-white transition-all duration-500 text-xl text-stone-400 group-hover:text-white">🌿</div>
            <h3 class="text-sm font-bold mb-3 tracking-wider">Amenities</h3>
            <p class="text-[11px] text-stone-500 leading-relaxed font-sans font-light">肌に優しい<br>オーガニック素材</p>
          </div>
          <div class="flex flex-col items-center group">
            <div class="w-14 h-14 mb-6 border border-stone-300 rounded-full flex items-center justify-center group-hover:bg-stone-900 group-hover:text-white transition-all duration-500 text-xl text-stone-400 group-hover:text-white">🛜</div>
            <h3 class="text-sm font-bold mb-3 tracking-wider">Fast Wi-Fi</h3>
            <p class="text-[11px] text-stone-500 leading-relaxed font-sans font-light">ストレスのない<br>通信環境を完備</p>
          </div>
          <div class="flex flex-col items-center group">
            <div class="w-14 h-14 mb-6 border border-stone-300 rounded-full flex items-center justify-center group-hover:bg-stone-900 group-hover:text-white transition-all duration-500 text-xl text-stone-400 group-hover:text-white">🌙</div>
            <h3 class="text-sm font-bold mb-3 tracking-wider">Sleep</h3>
            <p class="text-[11px] text-stone-500 leading-relaxed font-sans font-light">最高級の寝具で<br>極上の眠りを</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. ギャラリー -->
    <section id="gallery" class="py-40 px-4 scroll-mt-20 max-w-7xl mx-auto text-center">
      <span class="text-xs tracking-[0.4em] text-stone-400 block mb-12 uppercase font-sans">Gallery</span>
      <div class="grid grid-cols-12 gap-4">
        <div class="col-span-12 md:col-span-8 overflow-hidden aspect-[16/9] bg-stone-200">
          <img src="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?auto=format&fit=crop&w=1200&q=80" class="hover:scale-105 transition duration-1000 object-cover w-full h-full" alt="Room">
        </div>
        <div class="col-span-6 md:col-span-4 overflow-hidden aspect-square bg-stone-200">
          <img src="https://images.unsplash.com/photo-1584132967334-10e028bd69f7?auto=format&fit=crop&w=800&q=80" class="hover:scale-105 transition duration-1000 object-cover w-full h-full" alt="Detail">
        </div>
        <div class="col-span-6 md:col-span-4 overflow-hidden aspect-square bg-stone-200">
          <img src="https://images.unsplash.com/photo-1590490359683-658d3d23f972?auto=format&fit=crop&w=800&q=80" class="hover:scale-105 transition duration-1000 object-cover w-full h-full" alt="Detail">
        </div>
        <div class="col-span-12 md:col-span-8 overflow-hidden aspect-[16/9] bg-stone-200">
          <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?auto=format&fit=crop&w=1200&q=80" class="hover:scale-105 transition duration-1000 object-cover w-full h-full" alt="Landscape">
        </div>
      </div>
    </section>

    <!-- ★予約オプション・ハーフモーダル★ -->
    <div id="reserve-modal" class="fixed inset-0 z-[10000] pointer-events-none">
      <div id="modal-overlay" class="absolute inset-0 bg-stone-900/40 opacity-0 transition-opacity duration-500"></div>
      <div id="modal-sheet" class="absolute bottom-0 left-0 w-full bg-white rounded-t-[32px] p-8 translate-y-full transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] shadow-[0_-10px_40px_rgba(0,0,0,0.1)]">
        <div class="w-12 h-1.5 bg-stone-200 rounded-full mx-auto mb-8"></div>
        <h3 class="text-center text-stone-400 text-[10px] tracking-[0.3em] uppercase mb-8 font-sans">Select Booking Site</h3>
        <div class="flex flex-col gap-4 mb-8">
          <a href={airbnbLink} target="_blank" class="flex items-center justify-between p-5 bg-stone-50 rounded-2xl active:bg-stone-100 border border-stone-100">
            <span class="font-bold tracking-[0.2em] text-stone-800 text-sm">Airbnb</span>
            <span class="text-[#FF5A5F] font-bold">→</span>
          </a>
          <a href={bookingLink} target="_blank" class="flex items-center justify-between p-5 bg-stone-50 rounded-2xl active:bg-stone-100 border border-stone-100">
            <span class="font-bold tracking-[0.2em] text-stone-800 text-sm">Booking.com</span>
            <span class="text-[#003580] font-bold">→</span>
          </a>
        </div>
        <button id="modal-close" class="w-full py-4 text-stone-300 text-[10px] tracking-[0.3em] uppercase font-bold">Close</button>
      </div>
    </div>

    <!-- スマホ用固定Reserveボタン -->
    <div class="fixed bottom-10 left-1/2 -translate-x-1/2 z-[9999] md:hidden w-[80%] max-w-[320px]">
      <button id="open-reserve-sp" class="w-full bg-stone-900 text-white py-5 rounded-full font-bold shadow-2xl tracking-[0.4em] active:scale-95 transition-all text-sm">
        RESERVE
      </button>
    </div>

<!-- 6. フッター -->
    <footer class="bg-white border-t border-stone-100 pt-24 pb-32 md:pb-24 px-8">
      <div class="max-w-7xl mx-auto flex flex-col items-center">
        <!-- ロゴ再掲 -->
        <a href="/" class="text-xl tracking-[0.4em] font-light text-stone-800 mb-12 uppercase">{stayName}</a>
        
        <!-- ナビゲーションリンク -->
        <div class="flex flex-wrap justify-center gap-x-12 gap-y-6 mb-16 text-[10px] tracking-[0.2em] uppercase text-stone-400">
          <a href="#concept" class="hover:text-stone-900 transition">Concept</a>
          <a href="#amenities" class="hover:text-stone-900 transition">Amenities</a>
          <a href="#gallery" class="hover:text-stone-900 transition">Gallery</a>
          <a href={airbnbLink} target="_blank" class="hover:text-stone-900 transition">Airbnb</a>
          <a href={bookingLink} target="_blank" class="hover:text-stone-900 transition">Booking.com</a>
        </div>

        <!-- コピーライトとSNS（仮） -->
        <div class="flex flex-col items-center gap-8 w-full border-t border-stone-50 pt-12">
          <div class="flex gap-8 text-stone-300">
            <!-- SNSアイコンが必要な場合はここに追加 -->
            <a href="#" class="hover:text-stone-600 transition">Instagram</a>
            <a href="#" class="hover:text-stone-600 transition">Facebook</a>
          </div>
          <p class="text-[9px] text-stone-300 tracking-widest uppercase">
            &copy; 2026 {stayName}. All rights reserved.
          </p>
        </div>
      </div>
    </footer>
	
    <!-- 全体制御スクリプト -->
    <script is:inline>
      // 1. ハンバーガーメニュー制御
      const menuBtn = document.getElementById('menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const line1 = document.getElementById('line1');
      const line2 = document.getElementById('line2');
      const mobileLinks = document.querySelectorAll('.mobile-link');

      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('translate-x-full');
        line1?.classList.toggle('rotate-45');
        line1?.classList.toggle('translate-y-[3.5px]');
        line2?.classList.toggle('-rotate-45');
        line2?.classList.toggle('-translate-y-[3.5px]');
      });

      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('translate-x-full');
          line1?.classList.remove('rotate-45', 'translate-y-[3.5px]');
          line2?.classList.remove('-rotate-45', '-translate-y-[3.5px]');
        });
      });

      // 2. 予約モーダル制御 (PC/SP両方対応)
      const openSp = document.getElementById('open-reserve-sp');
      const openPc = document.getElementById('open-reserve-pc');
      const closeBtn = document.getElementById('modal-close');
      const overlay = document.getElementById('modal-overlay');
      const modal = document.getElementById('reserve-modal');
      const sheet = document.getElementById('modal-sheet');

      const toggleModal = (isOpen) => {
        if (isOpen) {
          modal.classList.remove('pointer-events-none');
          overlay.classList.replace('opacity-0', 'opacity-100');
          sheet.classList.replace('translate-y-full', 'translate-y-0');
        } else {
          modal.classList.add('pointer-events-none');
          overlay.classList.replace('opacity-100', 'opacity-0');
          sheet.classList.replace('translate-y-0', 'translate-y-full');
        }
      };

      openSp?.addEventListener('click', () => toggleModal(true));
      openPc?.addEventListener('click', () => toggleModal(true));
      closeBtn?.addEventListener('click', () => toggleModal(false));
      overlay?.addEventListener('click', () => toggleModal(false));
    </script>
  </body>
</html>